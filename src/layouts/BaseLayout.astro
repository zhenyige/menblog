---
interface Props {
  title?: string;
  description?: string;
  isPost?: boolean;
}

const {
  title = "Menblog",
  description = "个人学习、生活记录",
  isPost = false,
} = Astro.props;

const pageTitle = title === "Menblog" ? title : `${title} - Menblog`;
const pathname = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{pageTitle}</title>
  <meta name="description" content={description}>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;600;700&family=Noto+Sans+SC:wght@300;400;500;600&display=swap" rel="stylesheet">
</head>
<body>
  <!-- 顶部装饰条 -->
  <div class="top-bar"></div>

  <header class="site-header">
    <div class="header-inner">
      <a href="/" class="logo">
        <span class="logo-icon">📋</span>
        <span class="logo-text">Menblog</span>
      </a>
      <nav class="nav">
        <a href="/" class={pathname === "/" ? "nav-link active" : "nav-link"}>首页</a>
        <a href="/tags/资源" class={pathname === "/tags/资源" ? "nav-link active" : "nav-link"}>资源</a>
        <a href="/tags/技术" class="nav-link tag-tech">技术</a>
        <a href="/tags/游戏" class="nav-link tag-game">游戏</a>
        <a href="/tags/随笔" class="nav-link tag-life">随笔</a>
        <a href="/about" class={pathname === "/about/" ? "nav-link active" : "nav-link"}>关于</a>
      </nav>
    </div>
  </header>

  <main class="main-content">
    <slot />
  </main>

  <footer class="site-footer">
    <div class="footer-inner">
      <p>© 2026 Menblog · 用 <span class="heart">♥</span> 记录生活</p>
    </div>
  </footer>
</body>
</html>

<style is:global>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  :root {
    --bg: #FAFAF8;
    --card-bg: #FFFFFF;
    --text: #3D3D3D;
    --text-light: #8A8A8A;
    --border: #EDEDEA;
    --accent-green: #8FAE8B;
    --accent-pink: #C9A9A6;
    --accent-blue: #8EAFC2;
    --accent-orange: #D4A574;
    --shadow: 0 2px 12px rgba(0,0,0,0.06);
    --shadow-hover: 0 6px 24px rgba(0,0,0,0.10);
    --radius: 16px;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: 'Noto Sans SC', -apple-system, BlinkMacSystemFont, sans-serif;
    background-color: var(--bg);
    color: var(--text);
    line-height: 1.8;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  a {
    color: var(--text);
    text-decoration: none;
  }

  a:hover {
    text-decoration: none;
  }

  ::selection {
    background: rgba(142, 175, 194, 0.35);
  }

  ::-webkit-scrollbar {
    width: 6px;
  }
  ::-webkit-scrollbar-track {
    background: var(--bg);
  }
  ::-webkit-scrollbar-thumb {
    background: var(--border);
    border-radius: 3px;
  }
  ::-webkit-scrollbar-thumb:hover {
    background: var(--accent-blue);
  }

  h1, h2, h3 {
    font-family: 'Noto Serif SC', serif;
    font-weight: 700;
    color: #2A2A2A;
  }
</style>

<style>
  /* 顶部装饰条 */
  .top-bar {
    height: 4px;
    background: linear-gradient(90deg,
      var(--accent-green) 0%,
      var(--accent-blue) 33%,
      var(--accent-pink) 66%,
      var(--accent-orange) 100%
    );
  }

  /* Header */
  .site-header {
    background: var(--card-bg);
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 0;
    z-index: 100;
    backdrop-filter: blur(8px);
  }

  .header-inner {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 2rem;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
  }

  .logo-icon {
    font-size: 1.6rem;
  }

  .logo-text {
    font-family: 'Noto Serif SC', serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: #2A2A2A;
    letter-spacing: 0.05em;
  }

  .nav {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .nav-link {
    padding: 0.4rem 1rem;
    border-radius: 20px;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-light);
    transition: all 0.25s ease;
  }

  .nav-link:hover {
    color: var(--text);
    background: var(--bg);
  }

  .nav-link.active {
    background: var(--bg);
    color: var(--text);
    font-weight: 600;
  }

  .tag-tech:hover,
  .tag-tech.active { color: var(--accent-green); background: rgba(143,174,139,0.12); }
  .tag-game:hover,
  .tag-game.active { color: var(--accent-orange); background: rgba(212,165,116,0.12); }
  .tag-life:hover,
  .tag-life.active { color: var(--accent-pink); background: rgba(201,169,166,0.12); }

  /* Main */
  .main-content {
    flex: 1;
    max-width: 1000px;
    width: 100%;
    margin: 0 auto;
    padding: 2.5rem 2rem 3rem;
  }

  /* Footer */
  .site-footer {
    border-top: 1px solid var(--border);
    padding: 2rem 0;
    text-align: center;
  }

  .footer-inner {
    color: var(--text-light);
    font-size: 0.85rem;
  }

  .heart {
    color: var(--accent-pink);
  }

  /* Mobile */
  @media (max-width: 640px) {
    .header-inner {
      padding: 0 1rem;
    }
    .logo-text {
      font-size: 1.1rem;
    }
    .nav-link {
      padding: 0.35rem 0.7rem;
      font-size: 0.85rem;
    }
    .main-content {
      padding: 1.5rem 1rem 2rem;
    }
  }
</style>
