---
interface Props {
  title: string;
  date: string;
  description: string;
  tags: string[];
  slug: string;
}

const { title, date, description, tags, slug } = Astro.props;

// 莫兰迪色标签
const tagColors: Record<string, { bg: string; text: string }> = {
  '技术': { bg: 'rgba(143,174,139,0.15)', text: '#6B8B66' },
  '游戏': { bg: 'rgba(212,165,116,0.15)', text: '#B07840' },
  '随笔': { bg: 'rgba(201,169,166,0.15)', text: '#A07A78' },
};

const formatDate = (d: string) => {
  const [y, m, day] = d.split('T')[0].split('-');
  return `${parseInt(y)}年${parseInt(m)}月${parseInt(day)}日`;
};
---

<article class="card">
  <a href={`/post/${slug}/`} class="card-link">
    <div class="card-body">
      <div class="card-meta">
        <time class="card-date">{formatDate(date)}</time>
        <div class="card-tags">
          {tags.map(tag => {
            const c = tagColors[tag] || { bg: 'rgba(142,175,194,0.15)', text: '#6A8FA0' };
            return (
              <span class="tag" style={`background:${c.bg};color:${c.text}`}>{tag}</span>
            );
          })}
        </div>
      </div>
      <h2 class="card-title">{title}</h2>
      <p class="card-desc">{description}</p>
    </div>
    <div class="card-arrow">→</div>
  </a>
</article>

<style>
  .card {
    background: var(--card-bg);
    border-radius: var(--radius);
    border: 1px solid var(--border);
    transition: all 0.25s ease;
    overflow: hidden;
  }

  .card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-hover);
    border-color: transparent;
  }

  .card-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.5rem 1.75rem;
    text-decoration: none;
    color: inherit;
  }

  .card-body {
    flex: 1;
    min-width: 0;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.6rem;
    flex-wrap: wrap;
  }

  .card-date {
    font-size: 0.8rem;
    color: var(--text-light);
    font-weight: 400;
  }

  .card-tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 0.75rem;
    padding: 0.15rem 0.6rem;
    border-radius: 12px;
    font-weight: 500;
  }

  .card-title {
    font-family: 'Noto Serif SC', serif;
    font-size: 1.15rem;
    font-weight: 700;
    color: #2A2A2A;
    margin-bottom: 0.5rem;
    line-height: 1.5;
    transition: color 0.2s;
  }

  .card:hover .card-title {
    color: #5588BB;
  }

  .card-desc {
    font-size: 0.88rem;
    color: var(--text-light);
    line-height: 1.7;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-arrow {
    font-size: 1.2rem;
    color: var(--border);
    margin-left: 1rem;
    transition: all 0.25s ease;
    flex-shrink: 0;
  }

  .card:hover .card-arrow {
    color: #5588BB;
    transform: translateX(4px);
  }

  @media (max-width: 640px) {
    .card-link {
      padding: 1.2rem 1.25rem;
    }
    .card-title {
      font-size: 1.05rem;
    }
  }
</style>
