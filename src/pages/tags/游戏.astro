---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

// 获取所有文章，按日期降序排列
const posts = (await getCollection('blog'))
  .filter(post => (post.data.tags || []).includes('游戏'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const formattedDate = (date: Date) => new Date(date).toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: '2-digit',
  day: '2-digit'
});
---

<BaseLayout title="游戏 - Menblog">
  <main class="container">
    <header class="page-header">
      <div class="icon">🎮</div>
      <h1>游戏</h1>
      <p class="count">共 {posts.length} 篇文章</p>
    </header>

    <section class="posts">
      {posts.map(post => (
        <article class="post-item">
          <div class="post-meta">
            <time class="post-date">{formattedDate(post.data.date)}</time>
            {(post.data.tags || []).map(t => (
              <a href={`/tags/${t}`} class="tag-chip">{t}</a>
            ))}
          </div>
          <h2 class="post-title">
            <a href={`/post/${post.slug}`}>{post.data.title}</a>
          </h2>
          {post.data.description && (
            <p class="post-desc">{post.data.description}</p>
          )}
        </article>
      ))}
      {posts.length === 0 && (
        <div class="empty-state">
          <p>🎮 暂无游戏相关文章</p>
        </div>
      )}
    </section>

    <footer class="page-footer">
      <a href="/" class="back-link">← 返回首页</a>
    </footer>
  </main>
</BaseLayout>

<style>
  .container {
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  .page-header {
    text-align: center;
    padding: 2rem 0;
    border-bottom: 1px solid #eee;
    margin-bottom: 2rem;
  }

  .icon {
    font-size: 3rem;
    margin-bottom: 0.5rem;
  }

  .page-header h1 {
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }

  .count {
    color: #999;
    font-size: 0.9rem;
  }

  .posts {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .post-item {
    padding: 1rem 0;
    border-bottom: 1px solid #f0f0f0;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .post-date {
    color: #999;
    font-size: 0.85rem;
  }

  .tag-chip {
    background: #e8f0fe;
    color: #1a73e8;
    font-size: 0.75rem;
    padding: 0.1rem 0.5rem;
    border-radius: 4px;
    text-decoration: none;
  }

  .tag-chip:hover {
    background: #d0e0ff;
  }

  .post-title {
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
  }

  .post-title a {
    color: #333;
    text-decoration: none;
  }

  .post-title a:hover {
    color: #1a73e8;
  }

  .post-desc {
    color: #666;
    font-size: 0.95rem;
    margin-bottom: 0;
    line-height: 1.5;
  }

  .empty-state {
    text-align: center;
    padding: 3rem 0;
    color: #999;
    font-size: 1.1rem;
  }

  .page-footer {
    margin-top: 2rem;
    padding-top: 1rem;
  }

  .back-link {
    color: #1a73e8;
    text-decoration: none;
    font-size: 0.95rem;
  }

  .back-link:hover {
    text-decoration: underline;
  }
</style>
