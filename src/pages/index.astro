---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';

// 静态文章数据
const posts = [
  {
    slug: 'hostmybytes-promotion',
    title: '今天又收到hostmybytes的促销邮件',
    date: '2026-04-11',
    excerpt: '在今天，我们在数据中心上架了我们的新机器，并将在接下来的 24 小时内将所有服务重新向中国用户开放！'
  }
];
---

<BaseLayout title="Menblog - 个人学习,生活记录">
  <main class="container">
    <header class="hero">
      <h1>Menblog</h1>
      <p class="subtitle">个人学习,生活记录</p>
    </header>

    <section class="posts">
      <h2>最新文章</h2>
      <div class="post-list">
        {posts.map(post => (
          <PostCard post={post} />
        ))}
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .container {
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  .hero {
    text-align: center;
    padding: 3rem 0;
    border-bottom: 1px solid #eee;
    margin-bottom: 2rem;
  }

  .hero h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
  }

  .subtitle {
    color: #666;
    font-size: 1.1rem;
  }

  .posts h2 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
  }

  .post-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
</style>
