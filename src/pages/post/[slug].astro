---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { title, date, description, tags } = post.data;
const { Content } = await post.render();

const formattedDate = new Date(date).toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

<BaseLayout title={`${title} - Menblog`}>
  <main class="container">
    <article class="post">
      <header class="post-header">
        <div class="post-meta">
          <time class="post-date">{formattedDate}</time>
          {tags && tags.length > 0 && (
            <span class="post-tags">
              {tags.map(tag => <a href={`/tags/${tag}`} class="tag">{tag}</a>)}
            </span>
          )}
        </div>
        <h1 class="post-title">{title}</h1>
        {description && <p class="post-desc">{description}</p>}
      </header>

      <div class="post-content">
        <Content />
      </div>
    </article>

    <footer class="post-footer">
      <a href="/" class="back-link">← 返回首页</a>
    </footer>
  </main>
</BaseLayout>

<style>
  .container {
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  .post-header {
    padding-bottom: 1.5rem;
    border-bottom: 1px solid #eee;
    margin-bottom: 2rem;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .post-date {
    color: #999;
    font-size: 0.9rem;
  }

  .post-tags {
    display: flex;
    gap: 0.5rem;
  }

  .tag {
    background: #e8f0fe;
    color: #1a73e8;
    font-size: 0.75rem;
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    text-decoration: none;
  }

  .tag:hover {
    background: #d0e0ff;
  }

  .post-title {
    font-size: 2rem;
    margin-bottom: 0.75rem;
    line-height: 1.3;
  }

  .post-desc {
    color: #666;
    font-size: 1rem;
    line-height: 1.6;
  }

  .post-content {
    line-height: 1.8;
    font-size: 1.05rem;
  }

  .post-content :global(h2) {
    font-size: 1.5rem;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    color: #333;
  }

  .post-content :global(h3) {
    font-size: 1.25rem;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
    color: #444;
  }

  .post-content :global(p) {
    margin-bottom: 1rem;
  }

  .post-content :global(ul),
  .post-content :global(ol) {
    margin-bottom: 1rem;
    padding-left: 1.5rem;
  }

  .post-content :global(li) {
    margin-bottom: 0.3rem;
  }

  .post-content :global(a) {
    color: #0066cc;
  }

  .post-content :global(blockquote) {
    border-left: 4px solid #ddd;
    padding-left: 1rem;
    margin-left: 0;
    color: #666;
    margin-bottom: 1rem;
  }

  .post-content :global(code) {
    background: #f5f5f5;
    padding: 0.1rem 0.4rem;
    border-radius: 4px;
    font-size: 0.9em;
  }

  .post-content :global(pre) {
    background: #f5f5f5;
    padding: 1rem;
    border-radius: 8px;
    overflow-x: auto;
    margin-bottom: 1rem;
  }

  .post-content :global(pre code) {
    background: none;
    padding: 0;
  }

  .post-content :global(img) {
    max-width: 100%;
    border-radius: 8px;
    margin: 1rem 0;
  }

  .post-footer {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid #eee;
  }

  .back-link {
    color: #0066cc;
    text-decoration: none;
    font-size: 1rem;
  }

  .back-link:hover {
    text-decoration: underline;
  }
</style>
