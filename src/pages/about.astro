---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="关于 - Menblog">
  <div class="about-wrapper">

    <!-- 头像卡片 -->
    <div class="profile-card">
      <div class="avatar">🧑‍💻</div>
      <h1 class="name">Men</h1>
      <p class="bio">这家伙很懒，什么也没留下</p>
    </div>

    <!-- 联系信息 -->
    <div class="contact-card">
      <h2 class="section-title">联系方式</h2>
      <div class="contact-list">
        <a href="mailto:366604999@qq.com" class="contact-item">
          <span class="contact-icon">📧</span>
          <span class="contact-info">
            <span class="contact-label">邮箱</span>
            <span class="contact-value">366604999@qq.com</span>
          </span>
        </a>
        <a href="tencent://message/?uin=366604999" class="contact-item">
          <span class="contact-icon">💬</span>
          <span class="contact-info">
            <span class="contact-label">QQ</span>
            <span class="contact-value">366604999</span>
          </span>
        </a>
      </div>
    </div>

    <!-- 底部 -->
    <div class="about-footer">
      <a href="/" class="back-link">← 返回首页</a>
    </div>

  </div>
</BaseLayout>

<style>
  .about-wrapper {
    max-width: 580px;
    margin: 0 auto;
    padding-top: 1rem;
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }

  /* 头像卡片 */
  .profile-card {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 3rem 2rem;
    text-align: center;
    box-shadow: var(--shadow);
  }

  .avatar {
    width: 96px;
    height: 96px;
    background: linear-gradient(135deg, #8FAE8B, #8EAFC2);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 3rem;
    margin: 0 auto 1rem;
    box-shadow: 0 6px 20px rgba(143,174,139,0.3);
    transition: transform 0.3s;
  }

  .avatar:hover {
    transform: scale(1.06) rotate(5deg);
  }

  .name {
    font-family: 'Noto Serif SC', serif;
    font-size: 1.8rem;
    font-weight: 700;
    color: #1A1A1A;
    margin-bottom: 0.4rem;
  }

  .bio {
    color: var(--text-light);
    font-size: 0.9rem;
    font-style: italic;
    margin: 0;
  }

  /* 联系卡片 */
  .contact-card {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.75rem 2rem;
    box-shadow: var(--shadow);
  }

  .section-title {
    font-family: 'Noto Sans SC', sans-serif;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text-light);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 1.25rem;
  }

  .contact-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .contact-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.875rem 1.1rem;
    background: var(--bg);
    border-radius: 12px;
    text-decoration: none;
    border: 1px solid var(--border);
    transition: all 0.25s ease;
  }

  .contact-item:hover {
    border-color: var(--accent-blue);
    background: rgba(142,175,194,0.08);
    transform: translateX(4px);
    text-decoration: none;
  }

  .contact-icon {
    font-size: 1.4rem;
    width: 2.2rem;
    text-align: center;
    flex-shrink: 0;
  }

  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 0.05rem;
  }

  .contact-label {
    font-size: 0.72rem;
    color: var(--text-light);
    font-weight: 500;
  }

  .contact-value {
    font-size: 0.92rem;
    color: var(--text);
    font-weight: 500;
  }

  /* 底部 */
  .about-footer {
    text-align: center;
    padding: 0.5rem 0 1rem;
  }

  .back-link {
    display: inline-block;
    font-size: 0.85rem;
    color: var(--text-light);
    padding: 0.35rem 1rem;
    border-radius: 14px;
    border: 1px solid var(--border);
    transition: all 0.2s;
  }

  .back-link:hover {
    color: var(--text);
    border-color: var(--accent-blue);
    background: rgba(142,175,194,0.08);
    text-decoration: none;
  }

  @media (max-width: 640px) {
    .profile-card {
      padding: 2.5rem 1.5rem;
    }
    .contact-card {
      padding: 1.5rem 1.25rem;
    }
  }
</style>
